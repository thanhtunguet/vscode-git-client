{
  "name": "intelligit",
  "displayName": "IntelliGit Client",
  "description": "IntelliJ-like Git client for VS Code with branch tree, stashes, graph, merge/diff/compare workflows.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:intelliGit.branches",
    "onView:intelliGit.stashes",
    "onView:intelliGit.graph",
    "onCommand:intelliGit.quickActions"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intelliGit",
          "title": "IntelliGit",
          "icon": "media/intelligit.svg"
        }
      ]
    },
    "views": {
      "intelliGit": [
        {
          "id": "intelliGit.branches",
          "name": "Branches"
        },
        {
          "id": "intelliGit.stashes",
          "name": "Stashes"
        },
        {
          "id": "intelliGit.graph",
          "name": "Git Graph"
        }
      ]
    },
    "commands": [
      { "command": "intelliGit.refresh", "title": "IntelliGit: Refresh" },
      { "command": "intelliGit.quickActions", "title": "IntelliGit: Quick Git Actions" },
      { "command": "intelliGit.branch.checkout", "title": "IntelliGit: Checkout Branch" },
      { "command": "intelliGit.branch.create", "title": "IntelliGit: Create Branch" },
      { "command": "intelliGit.branch.rename", "title": "IntelliGit: Rename Branch" },
      { "command": "intelliGit.branch.delete", "title": "IntelliGit: Delete Branch" },
      { "command": "intelliGit.branch.track", "title": "IntelliGit: Track Remote Branch" },
      { "command": "intelliGit.branch.untrack", "title": "IntelliGit: Untrack Branch" },
      { "command": "intelliGit.branch.mergeIntoCurrent", "title": "IntelliGit: Merge Into Current" },
      { "command": "intelliGit.branch.rebaseOnto", "title": "IntelliGit: Rebase Current Onto Branch" },
      { "command": "intelliGit.branch.resetCurrentToCommit", "title": "IntelliGit: Reset Current Branch To Commit" },
      { "command": "intelliGit.branch.compareWithCurrent", "title": "IntelliGit: Compare With Current Branch" },
      { "command": "intelliGit.branch.search", "title": "IntelliGit: Search Branches" },
      { "command": "intelliGit.stash.create", "title": "IntelliGit: Create Stash" },
      { "command": "intelliGit.stash.apply", "title": "IntelliGit: Apply Stash" },
      { "command": "intelliGit.stash.pop", "title": "IntelliGit: Pop Stash" },
      { "command": "intelliGit.stash.drop", "title": "IntelliGit: Drop Stash" },
      { "command": "intelliGit.stash.rename", "title": "IntelliGit: Rename Stash" },
      { "command": "intelliGit.stash.previewPatch", "title": "IntelliGit: Preview Stash Patch" },
      { "command": "intelliGit.graph.openDetails", "title": "IntelliGit: Open Commit Details" },
      { "command": "intelliGit.graph.checkoutCommit", "title": "IntelliGit: Checkout Commit" },
      { "command": "intelliGit.graph.createBranchHere", "title": "IntelliGit: Create Branch At Commit" },
      { "command": "intelliGit.graph.cherryPick", "title": "IntelliGit: Cherry-pick Commit" },
      { "command": "intelliGit.graph.cherryPickRange", "title": "IntelliGit: Cherry-pick Commit Range" },
      { "command": "intelliGit.graph.revert", "title": "IntelliGit: Revert Commit" },
      { "command": "intelliGit.graph.rebaseInteractiveFromHere", "title": "IntelliGit: Interactive Rebase From Commit" },
      { "command": "intelliGit.graph.compareWithCurrent", "title": "IntelliGit: Compare Commit With Current" },
      { "command": "intelliGit.graph.filter", "title": "IntelliGit: Filter Graph" },
      { "command": "intelliGit.graph.clearFilter", "title": "IntelliGit: Clear Graph Filters" },
      { "command": "intelliGit.diff.open", "title": "IntelliGit: Open Diff" },
      { "command": "intelliGit.compare.open", "title": "IntelliGit: Compare Branches" },
      { "command": "intelliGit.merge.openConflict", "title": "IntelliGit: Open Conflict In Merge Editor" },
      { "command": "intelliGit.merge.next", "title": "IntelliGit: Next Conflict" },
      { "command": "intelliGit.merge.previous", "title": "IntelliGit: Previous Conflict" },
      { "command": "intelliGit.merge.finalize", "title": "IntelliGit: Finalize Merge Resolution" },
      { "command": "intelliGit.git.pushWithPreview", "title": "IntelliGit: Push (Preview)" },
      { "command": "intelliGit.git.pullWithPreview", "title": "IntelliGit: Pull (Preview)" },
      { "command": "intelliGit.git.fetchPrune", "title": "IntelliGit: Fetch --prune" },
      { "command": "intelliGit.stage.patch", "title": "IntelliGit: Stage Selected Hunks" },
      { "command": "intelliGit.stage.file", "title": "IntelliGit: Stage File" },
      { "command": "intelliGit.unstage.file", "title": "IntelliGit: Unstage File" },
      { "command": "intelliGit.commit.amend", "title": "IntelliGit: Amend Last Commit" },
      { "command": "intelliGit.fileHistory.open", "title": "IntelliGit: Open File History" },
      { "command": "intelliGit.fileBlame.open", "title": "IntelliGit: Open File Blame" }
    ],
    "menus": {
      "view/title": [
        {
          "command": "intelliGit.refresh",
          "when": "view =~ /^intelliGit\\./",
          "group": "navigation"
        },
        {
          "command": "intelliGit.quickActions",
          "when": "view =~ /^intelliGit\\./",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "intelliGit.branch.checkout",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "inline"
        },
        {
          "command": "intelliGit.branch.compareWithCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation"
        },
        {
          "command": "intelliGit.branch.rename",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.branch.delete",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.branch.track",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.branch.untrack",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.branch.mergeIntoCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@5"
        },
        {
          "command": "intelliGit.branch.rebaseOnto",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@6"
        },
        {
          "command": "intelliGit.stash.apply",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "inline"
        },
        {
          "command": "intelliGit.stash.pop",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation"
        },
        {
          "command": "intelliGit.stash.rename",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.stash.drop",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.stash.previewPatch",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation"
        },
        {
          "command": "intelliGit.graph.openDetails",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "inline"
        },
        {
          "command": "intelliGit.graph.checkoutCommit",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation"
        },
        {
          "command": "intelliGit.graph.createBranchHere",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.graph.cherryPick",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.graph.revert",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.graph.compareWithCurrent",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "IntelliGit",
      "properties": {
        "intelliGit.gitPath": {
          "type": "string",
          "default": "git",
          "description": "Git executable path."
        },
        "intelliGit.commandTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 2000,
          "description": "Timeout for Git commands in milliseconds."
        },
        "intelliGit.maxGraphCommits": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "Maximum commits shown in Git Graph view."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "lint": "eslint src --ext .ts",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}
