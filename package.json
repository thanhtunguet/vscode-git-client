{
  "name": "vscode-git-client",
  "displayName": "IntelliGit Client",
  "description": "IntelliJ-like Git client for VS Code with branch tree, stashes, graph, merge/diff/compare workflows.",
  "version": "0.1.2",
  "publisher": "thanhtunguet",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thanhtunguet/vscode-git-client"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:intelliGit.branches",
    "onView:intelliGit.stashes",
    "onView:intelliGit.graph",
    "onView:intelliGit.commitView",
    "onCommand:intelliGit.quickActions"
  ],
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "lint": "eslint src --ext .ts",
    "test": "npm run compile"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intelliGit",
          "title": "IntelliGit",
          "icon": "media/intelligit.svg"
        }
      ]
    },
    "views": {
      "intelliGit": [
        {
          "id": "intelliGit.branches",
          "name": "Branches",
          "visibility": "visible",
          "icon": "media/intelligit.svg"
        },
        {
          "id": "intelliGit.stashes",
          "name": "Stashes",
          "visibility": "visible",
          "icon": "media/intelligit.svg"
        },
        {
          "id": "intelliGit.graph",
          "name": "Git Graph",
          "visibility": "visible",
          "icon": "media/intelligit.svg"
        }
      ],
      "panel": [
        {
          "id": "intelliGit.commitView",
          "name": "Commit View",
          "when": "intelliGit.commitViewVisible"
        }
      ]
    },
    "commands": [
      {
        "command": "intelliGit.refresh",
        "title": "Refresh"
      },
      {
        "command": "intelliGit.quickActions",
        "title": "Quick Git Actions"
      },
      {
        "command": "intelliGit.branch.checkout",
        "title": "Checkout Branch"
      },
      {
        "command": "intelliGit.branch.create",
        "title": "Create Branch"
      },
      {
        "command": "intelliGit.branch.rename",
        "title": "Rename Branch"
      },
      {
        "command": "intelliGit.branch.delete",
        "title": "Delete Branch"
      },
      {
        "command": "intelliGit.branch.track",
        "title": "Track Remote Branch"
      },
      {
        "command": "intelliGit.branch.untrack",
        "title": "Untrack Branch"
      },
      {
        "command": "intelliGit.branch.mergeIntoCurrent",
        "title": "Merge Into Current"
      },
      {
        "command": "intelliGit.branch.rebaseOnto",
        "title": "Rebase Current Onto Branch"
      },
      {
        "command": "intelliGit.branch.resetCurrentToCommit",
        "title": "Reset Current Branch To Commit"
      },
      {
        "command": "intelliGit.branch.compareWithCurrent",
        "title": "Compare With Current Branch"
      },
      {
        "command": "intelliGit.branch.search",
        "title": "Search Branches"
      },
      {
        "command": "intelliGit.stash.create",
        "title": "Create Stash"
      },
      {
        "command": "intelliGit.stash.apply",
        "title": "Apply Stash"
      },
      {
        "command": "intelliGit.stash.pop",
        "title": "Pop Stash"
      },
      {
        "command": "intelliGit.stash.drop",
        "title": "Drop Stash"
      },
      {
        "command": "intelliGit.stash.rename",
        "title": "Rename Stash"
      },
      {
        "command": "intelliGit.stash.previewPatch",
        "title": "Preview Stash Patch"
      },
      {
        "command": "intelliGit.graph.openDetails",
        "title": "Open Commit Details"
      },
      {
        "command": "intelliGit.graph.openFileDiff",
        "title": "Open Commit File Diff"
      },
      {
        "command": "intelliGit.graph.checkoutCommit",
        "title": "Checkout Commit"
      },
      {
        "command": "intelliGit.graph.createBranchHere",
        "title": "Create Branch At Commit"
      },
      {
        "command": "intelliGit.graph.createTagHere",
        "title": "Create Tag At Commit"
      },
      {
        "command": "intelliGit.graph.cherryPick",
        "title": "Cherry-pick Commit"
      },
      {
        "command": "intelliGit.graph.cherryPickRange",
        "title": "Cherry-pick Commit Range"
      },
      {
        "command": "intelliGit.graph.revert",
        "title": "Revert Commit"
      },
      {
        "command": "intelliGit.graph.rebaseInteractiveFromHere",
        "title": "Interactive Rebase From Commit"
      },
      {
        "command": "intelliGit.graph.compareWithCurrent",
        "title": "Compare Commit With Current"
      },
      {
        "command": "intelliGit.graph.createPatch",
        "title": "Create Patch From Commit"
      },
      {
        "command": "intelliGit.graph.showRepositoryAtRevision",
        "title": "Show Repository At Revision"
      },
      {
        "command": "intelliGit.graph.goToParentCommit",
        "title": "Go To Parent Commit"
      },
      {
        "command": "intelliGit.graph.filter",
        "title": "Filter Graph"
      },
      {
        "command": "intelliGit.graph.clearFilter",
        "title": "Clear Graph Filters"
      },
      {
        "command": "intelliGit.diff.open",
        "title": "Open Diff"
      },
      {
        "command": "intelliGit.compare.open",
        "title": "Compare Branches"
      },
      {
        "command": "intelliGit.merge.openConflict",
        "title": "Open Conflict In Merge Editor"
      },
      {
        "command": "intelliGit.merge.next",
        "title": "Next Conflict"
      },
      {
        "command": "intelliGit.merge.previous",
        "title": "Previous Conflict"
      },
      {
        "command": "intelliGit.merge.finalize",
        "title": "Finalize Merge Resolution"
      },
      {
        "command": "intelliGit.git.pushWithPreview",
        "title": "Push (Preview)"
      },
      {
        "command": "intelliGit.git.pullWithPreview",
        "title": "Pull (Preview)"
      },
      {
        "command": "intelliGit.git.fetchPrune",
        "title": "Fetch --prune"
      },
      {
        "command": "intelliGit.stage.patch",
        "title": "Stage Selected Hunks"
      },
      {
        "command": "intelliGit.stage.file",
        "title": "Stage File"
      },
      {
        "command": "intelliGit.unstage.file",
        "title": "Unstage File"
      },
      {
        "command": "intelliGit.commit.amend",
        "title": "Amend Last Commit"
      },
      {
        "command": "intelliGit.fileHistory.open",
        "title": "Open File History"
      },
      {
        "command": "intelliGit.fileBlame.open",
        "title": "Open File Blame"
      }
    ],
    "keybindings": [
      {
        "command": "workbench.action.closeActiveEditor",
        "key": "escape",
        "when": "textCompareEditorVisible && editorTextFocus && !findWidgetVisible && !suggestWidgetVisible"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "intelliGit.refresh",
          "when": "view == intelliGit.branches || view == intelliGit.stashes || view == intelliGit.graph",
          "group": "navigation"
        },
        {
          "command": "intelliGit.quickActions",
          "when": "view == intelliGit.branches || view == intelliGit.stashes || view == intelliGit.graph",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "intelliGit.branch.checkout",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "inline"
        },
        {
          "command": "intelliGit.branch.compareWithCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation"
        },
        {
          "command": "intelliGit.branch.rename",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.branch.delete",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.branch.track",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.branch.untrack",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.branch.mergeIntoCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@5"
        },
        {
          "command": "intelliGit.branch.rebaseOnto",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@6"
        },
        {
          "command": "intelliGit.stash.apply",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "inline"
        },
        {
          "command": "intelliGit.stash.pop",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation"
        },
        {
          "command": "intelliGit.stash.rename",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.stash.drop",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.stash.previewPatch",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation"
        },
        {
          "command": "intelliGit.graph.openDetails",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "inline"
        },
        {
          "command": "intelliGit.graph.openFileDiff",
          "when": "view == intelliGit.graph && viewItem == graphCommitFile",
          "group": "inline"
        },
        {
          "command": "intelliGit.graph.checkoutCommit",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation"
        },
        {
          "command": "intelliGit.graph.createBranchHere",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.graph.cherryPick",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.graph.revert",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.graph.compareWithCurrent",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.graph.openFileDiff",
          "when": "view == intelliGit.commitView && viewItem == commitViewFile",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "IntelliGit",
      "properties": {
        "intelliGit.gitPath": {
          "type": "string",
          "default": "git",
          "description": "Git executable path."
        },
        "intelliGit.commandTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 2000,
          "description": "Timeout for Git commands in milliseconds."
        },
        "intelliGit.maxGraphCommits": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "Maximum commits shown in Git Graph view."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}
